{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": "dist-test",
    "lib": ["ES2020", "DOM"]
  },
  "include": ["src/core/**/*.ts", "src/types/**/*.ts", "src/modules/**/*.ts", "tests/**/*.ts"]
}
